class Solution(object):
    def longestCommonPrefix(self, strs):
        prefix=strs[0]
        for i in range (1,len(strs)):
            temp=""
            j=0
            while j<len(prefix) and j<len(strs[i]):
                if prefix[j]==strs[i][j]:
                    temp+=prefix[j]
                else:
                    break
                j+=1
            prefix=temp
            if prefix=="":
                return ""
        return prefix                    
